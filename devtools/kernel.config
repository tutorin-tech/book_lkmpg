# Minimal kernel config fragment for lkmpg QEMU guest.
# Merged on top of defconfig via scripts/kconfig/merge_config.sh.

# Module support (core requirement)
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y

# Initramfs boot
CONFIG_BLK_DEV_INITRD=y

# 9p filesystem -- share host examples/ into guest without rootfs rebuild
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETWORK_FILESYSTEMS=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y

# Virtio transport for 9p
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y

# procfs (procfs1-4 examples)
CONFIG_PROC_FS=y

# sysfs (hello-sysfs example)
CONFIG_SYSFS=y

# debugfs (hello-debugfs, hello-debugfs-file examples)
CONFIG_DEBUG_FS=y
CONFIG_DEBUG_FS_ALLOW_ALL=y

# Block layer (blkram example)
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_RAM=y

# Input subsystem (vinput, vkbd examples)
CONFIG_INPUT=y
CONFIG_INPUT_MISC=y
CONFIG_INPUT_UINPUT=y

# Networking (vnetloop example)
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_DUMMY=y

# Serial console
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y

# Printk timestamps (useful for dmesg inspection)
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y

# GDB kernel debugging
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_KERNEL=y
CONFIG_GDB_SCRIPTS=y
CONFIG_FRAME_POINTER=y

# Symbol resolution for debugging
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y

# Disable KASLR so GDB addresses are stable
# CONFIG_RANDOMIZE_BASE is not set

# Trim unnecessary subsystems for faster boot
# CONFIG_SOUND is not set
# CONFIG_USB is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BLUETOOTH is not set
# CONFIG_NFS_FS is not set
# CONFIG_CIFS is not set
